{
    "configurations": [
        {
            "name": "MinGW64",
            "configurationProvider": "ms-vscode.cmake-tools", //새로 추가 경로 파일 인식 못할때 
            "includePath": [
                "${workspaceFolder}/",
                "/usr/include/**",
                "${workspaceFolder}/include"
            ],
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE"
            ],
            "compilerPath": "/usr/bin/g++",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-x64"
        }
    ],
    "version": 4
}